# Copy to .env and fill in. Anything left blank will fail at app startup.

# Placeholder so iOS / worker setup docs don't break — NOT read by this PR.
GEMINI_API_KEY=

# Sign session JWTs (HS256). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SIGNING_KEY=

# Apple Sign-in audience claim. Hardcoded to the production bundle id; override
# in tests / staging if needed.
APPLE_BUNDLE_ID=com.almond.app

# MongoDB connection. Atlas SRV string in production; mongodb://localhost:27017
# for local development.
MONGODB_URI=
MONGODB_DB=almond

# Shared bearer token used by the offline worker process to call the
# /uploads/* endpoints. Different from session JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
WORKER_API_KEY=
