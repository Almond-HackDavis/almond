# Copy to .env and fill in. The app fails to start if any required value is blank.

# ── Required ────────────────────────────────────────────────────────────────
# Atlas SRV string in production; mongodb://localhost:27017 for local dev.
MONGODB_URI=
MONGODB_DB=almond

# Google AI Studio API key. Used to call the Gemma model. The genai SDK
# accepts the same key for both Gemma and Gemini — set GEMINI_API_KEY too if
# you keep an existing one in your shell, gemma.summarize() will read either.
GEMMA_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# Override the default Gemma model. Leave blank to use gemma-3-27b-it.
GEMMA_MODEL=
